{
	"name": "vault",
	"type": "module",
	"private": true,
	"version": "0.0.1",
	"scripts": {
		"analyze:knowledge-base": "bun scripts/analyze-knowledge-base.ts",
		"qmd:index": "bun scripts/build-qmd-index.ts",
		"portless:stop": "sudo portless proxy stop",
		"portless:start": "sudo portless proxy start --https -p 443",
		"dev": "portless run bun --bun vite dev",
		"build": "bun --bun vite build",
		"typecheck": "tsgo",
		"check:staged": "bun --bun biome check --write --staged",
		"check": "bun --bun biome check --write",
		"prepare": "effect-tsgo patch"
	},
	"dependencies": {
		"@base-ui/react": "^1.3.0",
		"@effect/platform-bun": "4.0.0-beta.31",
		"@fontsource-variable/raleway": "^5.2.8",
		"@mantine/hooks": "^8.3.17",
		"@tailwindcss/vite": "^4.2.1",
		"@tanstack/react-router": "^1.167.0",
		"@tanstack/react-start": "^1.166.11",
		"@tobilu/qmd": "^2.0.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"effect": "^4.0.0-beta.31",
		"lucide-react": "^0.577.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-resizable-panels": "^4.7.3",
		"shadcn": "^4.0.7",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"vaul": "^1.1.2"
	},
	"devDependencies": {
