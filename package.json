		"@types/bun": "^1.3.10",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260315.1",
		"@vitejs/plugin-react": "^6.0.1",
		"vite": "^8.0.0",
		"vite-plugin-pwa": "^1.2.0"
	}
